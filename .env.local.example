# =============================================================================
# Amphibian Unite — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values
#
# Phase 1: Authentication (Clerk)
# --------------------------------
# Sign up at https://clerk.com and create an application.
# Go to API Keys in the Clerk dashboard to get these values.
#
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# =============================================================================
# Phase 2: Database (Supabase) — uncomment when ready
# =============================================================================
# Sign up at https://supabase.com and create a project.
# Go to Settings > API to get these values.
#
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# =============================================================================
# Phase 3: AI Agents (Claude API) — uncomment when ready
# =============================================================================
# ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# Phase 4: Integrations — uncomment when ready
# =============================================================================
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...

# =============================================================================
# App Config
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
